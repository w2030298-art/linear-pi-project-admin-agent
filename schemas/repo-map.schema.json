{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RepoMap",
  "type": "object",
  "required": ["version", "repos"],
  "properties": {
    "version": { "const": 1 },
    "repos": {
      "type": "array",
      "items": { "$ref": "#/$defs/repoMapEntry" }
    }
  },
  "$defs": {
    "repoMapEntry": {
      "type": "object",
      "required": ["repoKey", "github", "linear", "localPath", "docs", "evidenceWeight"],
      "properties": {
        "repoKey": { "type": "string", "minLength": 1 },
        "github": {
          "type": "object",
          "required": ["owner", "repo", "defaultBranch"],
          "properties": {
            "owner": { "type": "string", "minLength": 1 },
            "repo": { "type": "string", "minLength": 1 },
            "defaultBranch": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "linear": {
          "type": "object",
          "properties": {
            "projectId": { "type": "string", "minLength": 1 },
            "projectName": { "type": "string", "minLength": 1 },
            "projectPrefix": { "type": "string", "minLength": 1 }
          },
          "anyOf": [
            { "required": ["projectId"] },
            { "required": ["projectName"] },
            { "required": ["projectPrefix"] }
          ],
          "additionalProperties": false
        },
        "localPath": { "type": "string", "minLength": 1 },
        "docs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "evidenceWeight": { "enum": ["high", "medium", "low"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
