{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LinearProjectAdminFactPack",
  "type": "object",
  "required": ["id", "createdAt", "scope", "facts", "assumptions", "openQuestions", "conflicts", "evidenceGaps", "planningImplications"],
  "properties": {
    "id": { "type": "string" },
    "createdAt": { "type": "string" },
    "scope": { "type": "object" },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "sourceType", "source", "confidence"],
        "properties": {
          "claim": { "type": "string" },
          "sourceType": { "enum": ["repo_map", "linear_live", "github_remote", "local_repo", "local_docs", "web_search", "user_input", "agent_state"] },
          "source": { "type": "string" },
          "timestamp": { "type": ["string", "null"] },
          "confidence": { "enum": ["high", "medium", "low"] },
          "rawRef": { "type": ["string", "null"] },
          "evidenceRef": { "type": ["string", "null"] },
          "summary": { "type": ["string", "null"] }
        }
      }
    },
    "evidenceManifest": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sourceType", "source", "path"],
        "properties": {
          "sourceType": { "type": "string" },
          "source": { "type": "string" },
          "path": { "type": "string" },
          "summary": { "type": ["string", "null"] }
        }
      }
    },
    "projectBaseline": {
      "type": ["object", "null"],
      "properties": {
        "kind": { "const": "linear_project_baseline" },
        "collectedAt": { "type": "string" },
        "rawEvidenceRef": { "type": ["string", "null"] },
        "project": { "type": "object" },
        "counts": { "type": "object" },
        "latestUpdatedAt": { "type": ["string", "null"] },
        "issueSample": { "type": "array" },
        "milestoneSample": { "type": "array" },
        "updateSample": { "type": "array" }
      }
    },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "openQuestions": { "type": "array", "items": { "type": "string" } },
    "conflicts": { "type": "array", "items": { "type": "string" } },
    "evidenceGaps": { "type": "array", "items": { "type": "string" } },
    "planningImplications": { "type": "array", "items": { "type": "string" } }
  }
}
