{
  "name": "linear-pi-project-admin-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A Pi Agent project scaffold for a Linear-native project administrator with GitHub, local repo/docs, and web evidence sources.",
  "scripts": {
    "validate": "node scripts/validate-layout.mjs",
    "fact:local": "node scripts/local-evidence.mjs --root .",
    "fact:repo": "node scripts/github-evidence.mjs snapshot",
    "fact:web": "node scripts/web-search.mjs",
    "fact:pack": "node scripts/fact-pack.mjs",
    "repo-map:drift": "node scripts/repo-map-drift.mjs",
    "plan:review": "node scripts/plan-reviewer.mjs",
    "project:freeze": "node scripts/project-governance-template.mjs freeze",
    "project:unfreeze": "node scripts/project-governance-template.mjs unfreeze",
    "linear:smoke": "node scripts/linear-cli.mjs smoke",
    "linear:workspace": "node scripts/linear-cli.mjs workspace",
    "bridge:dev": "tsx services/linear-bridge/src/server.ts",
    "bridge:start": "node dist/services/linear-bridge/src/server.js",
    "test:webhook-signature": "node scripts/test-webhook-signature.mjs",
    "test:plan-review": "node scripts/test-plan-reviewer.mjs",
    "test:project-description-fields": "node scripts/test-project-description-fields.mjs",
    "test:repo-map": "node scripts/test-repo-map.mjs",
    "test:repo-map-drift": "node scripts/test-repo-map-drift.mjs",
    "test:pi-ask-user": "tsx scripts/test-pi-ask-user-repo-map.ts",
    "test:wezterm-launch": "node scripts/test-wezterm-launch-docs.mjs",
    "test:runtime-reload-master": "tsx scripts/test-runtime-reload-master.ts",
    "test:runtime-local-protection": "node scripts/test-runtime-local-protection.mjs",
    "test:runtime-instruction-boundary": "node scripts/test-runtime-instruction-boundary.mjs",
    "test:unsupported-fields": "tsx scripts/test-write-plan-unsupported-fields.ts",
    "test:linear-apply-mode": "node scripts/test-linear-apply-mode.mjs",
    "test:linear-snapshot": "node scripts/test-linear-snapshot.mjs",
    "test:issue-resolver": "node scripts/test-linear-issue-resolver.mjs",
    "test:project-resolver": "node scripts/test-linear-project-resolver.mjs",
    "test:project-governance": "node scripts/test-project-governance-template.mjs",
    "test:project-status": "node scripts/test-linear-project-status-resolver.mjs",
    "test:object-resolver": "node scripts/test-linear-object-resolver.mjs",
    "test:project-baseline": "node scripts/test-project-baseline-loader.mjs",
    "test:retrieval-ux": "node scripts/test-retrieval-ux.mjs",
    "test:write-confirmation": "tsx scripts/test-write-confirmation-ux.ts",
    "test:pipeline-refactor-goals": "tsx scripts/test-pipeline-refactor-goals.mjs"
  },
  "dependencies": {
    "@linear/sdk": "latest",
    "@modelcontextprotocol/sdk": "latest",
    "@tavily/core": "latest",
    "dotenv": "latest",
    "express": "latest",
    "fast-glob": "latest",
    "yaml": "latest",
    "zod": "latest",
    "typebox": "latest"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "latest",
    "@types/express": "latest",
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
