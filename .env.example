# Linear
LINEAR_API_KEY=lin_api_xxx
LINEAR_WEBHOOK_SECRET=whsec_xxx
LINEAR_DEFAULT_TEAM_KEY=ENG
LINEAR_DEFAULT_TEAM_ID=
LINEAR_WORKSPACE_URL_KEY=
LINEAR_WRITE_MODE=dry-run

# GitHub MCP / REST fallback
GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_xxx
GITHUB_TOOLSETS=repos,issues,pull_requests,actions
GITHUB_FACT_MODE=rest
GITHUB_DEFAULT_OWNER=
GITHUB_DEFAULT_REPO=

# Local evidence roots, comma-separated. Keep narrow.
LOCAL_REPO_ROOTS=./repos
LOCAL_DOC_ROOTS=./docs,./research

# Web research provider: tavily | brave | off
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=tvly_xxx
BRAVE_SEARCH_API_KEY=
WEB_SEARCH_MAX_RESULTS=8
WEB_SEARCH_DEFAULT_DAYS=365

# Pi runner / bridge
PI_COMMAND=pi
PI_MODE=rpc
PI_SESSION_DIR=.pi/sessions
PI_AUTO_RUN=false
BRIDGE_PORT=8787
PUBLIC_BASE_URL=https://example.ngrok-free.app

# Security
ALLOW_LINEAR_WRITES=false
ALLOW_GITHUB_WRITES=false
ALLOW_WEB_SEARCH=true
FACT_PACK_REQUIRED=true
AUDIT_LOG_PATH=state/audit.jsonl
